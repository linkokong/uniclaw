{
  "name": "claw-universe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "load:light": "k6 run tests/load/k6-script.js --env SCENARIO=light  --out json=tests/load/results/light.json",
    "load:medium": "k6 run tests/load/k6-script.js --env SCENARIO=medium --out json=tests/load/results/medium.json",
    "load:heavy": "k6 run tests/load/k6-script.js --env SCENARIO=heavy  --out json=tests/load/results/heavy.json",
    "load:all": "./tests/load/run-load-test.sh"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@coral-xyz/borsh": "^0.32.1",
    "@noble/hashes": "^2.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.95.4",
    "@tanstack/react-query": "^5.56.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bn.js": "^5.2.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "express": "^5.2.1",
    "happy-dom": "^20.8.9",
    "helmet": "^8.1.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.45",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.2"
  }
}
